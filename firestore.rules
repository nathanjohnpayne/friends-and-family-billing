rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own top-level document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Year-scoped billing data — owner only
      match /billingYears/{yearId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Disputes — owner can read/write; unauthenticated users can create/update
        // via share token (validated against publicShares collection)
        match /disputes/{disputeId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;

          // Allow dispute creation from share page (no auth) if token is valid
          allow create: if request.auth == null
            && request.resource.data.keys().hasAll(['tokenHash', 'memberId', 'memberName', 'billId', 'billName', 'message', 'status', 'createdAt'])
            && request.resource.data.status == 'open'
            && request.resource.data.message is string
            && request.resource.data.message.size() > 0
            && request.resource.data.message.size() <= 2000
            && exists(/databases/$(database)/documents/publicShares/$(request.resource.data.tokenHash))
            && get(/databases/$(database)/documents/publicShares/$(request.resource.data.tokenHash)).data.ownerId == userId
            && get(/databases/$(database)/documents/publicShares/$(request.resource.data.tokenHash)).data.billingYearId == yearId
            && get(/databases/$(database)/documents/publicShares/$(request.resource.data.tokenHash)).data.scopes.hasAny(['disputes:create']);

          // Allow dispute decision updates from share page (no auth)
          allow update: if request.auth == null
            && resource.data.tokenHash is string
            && exists(/databases/$(database)/documents/publicShares/$(resource.data.tokenHash))
            && get(/databases/$(database)/documents/publicShares/$(resource.data.tokenHash)).data.ownerId == userId
            && get(/databases/$(database)/documents/publicShares/$(resource.data.tokenHash)).data.scopes.hasAny(['disputes:read'])
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'userReview', 'resolvedAt']);
        }
      }

      // Audit log — owner can read, only server (Admin SDK) can write
      match /auditLog/{logId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // Share tokens: admin CRUD scoped to own tokens.
    // The Cloud Function uses the Admin SDK (bypasses these rules)
    // to resolve tokens on behalf of unauthenticated share-link visitors.
    match /shareTokens/{tokenId} {
      allow read, update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.keys().hasAll(['ownerId', 'memberId', 'billingYearId', 'scopes', 'revoked'])
        && request.resource.data.revoked == false;

      allow list: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // Public share data — anyone with the token hash can read.
    // Only the owner can write (via the main app after generating a share link).
    // Unauthenticated visitors may increment accessCount/lastAccessedAt only.
    match /publicShares/{tokenHash} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      allow update: if request.auth == null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['accessCount', 'lastAccessedAt']);

      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // Public QR codes — anyone can read (separated from publicShares to avoid
    // document size limits). Owner can write via the main app.
    match /publicQrCodes/{docId} {
      allow read: if true;

      allow create, update: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // Deny everything else by default (implicit, but explicit for clarity)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
