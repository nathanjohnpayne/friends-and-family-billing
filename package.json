{
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run build:legacy && npm run build:react",
    "build:legacy": "esbuild src/index.js --bundle --format=iife --outfile=script.js --sourcemap",
    "build:react": "vite build",
    "build:watch": "esbuild src/index.js --bundle --format=iife --outfile=script.js --sourcemap --watch",
    "dev": "vite --open",
    "pr:auto": "node scripts/pr-auto.mjs",
    "preview": "vite preview",
    "test": "npm run test:legacy && npm run test:react && npm run test:secrets",
    "test:legacy": "npm run build:legacy && node --test 'tests/*.test.js'",
    "test:react": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build:react && npx playwright test",
    "test:secrets": "node scripts/check-no-public-secrets.mjs",
    "deploy": "op-firebase-deploy --only hosting,firestore:rules,storage",
    "deploy:functions": "op-firebase-deploy --only functions",
    "deploy:all": "op-firebase-deploy"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "esbuild": "^0.27.3",
    "jsdom": "^29.0.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@tiptap/extension-link": "^3.22.1",
    "@tiptap/extension-placeholder": "^3.22.1",
    "@tiptap/pm": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "@tiptap/suggestion": "^3.22.1",
    "firebase": "^12.11.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  }
}
