{
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run build:react && npm run build:assemble",
    "build:react": "vite build",
    "build:assemble": "node scripts/assemble-deploy.js",
    "postinstall": "cd functions && npm install",
    "dev": "vite --open",
    "pr:auto": "node scripts/pr-auto.mjs",
    "preview": "vite preview",
    "test": "npm run test:react && npm run test:functions && npm run test:secrets",
    "test:functions": "node --test 'tests/functions.test.js'",
    "test:react": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "export VITE_E2E_MODE=true && npm run build:react && npm run build:assemble && npx playwright test",
    "test:secrets": "node scripts/check-no-public-secrets.mjs",
    "lint": "eslint .",
    "deploy": "op-firebase-deploy --only hosting,firestore:rules,storage",
    "deploy:functions": "op-firebase-deploy --only functions",
    "deploy:all": "op-firebase-deploy"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/suggestion": "^3.27.1",
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  }
}
