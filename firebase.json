{
  "hosting": {
    "public": "app",
    "predeploy": [
      "npm run build && node stamp-version.js"
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "regex": "/app/(?P<path>.*)",
        "destination": "/:path",
        "type": 301
      },
      {
        "source": "/app",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/login.html",
        "destination": "/login",
        "type": 301
      },
      {
        "source": "/check_data.html",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/share.html",
        "destination": "/share",
        "type": 301
      },
      {
        "source": "/site/share.html",
        "destination": "/share",
        "type": 301
      },
      {
        "source": "/site/**",
        "destination": "/",
        "type": 301
      }
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "version.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "favicon.svg",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "qr-code.svg",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "og-image.png",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/resolveShareToken",
        "function": "resolveShareToken"
      },
      {
        "source": "/submitDispute",
        "function": "submitDispute"
      },
      {
        "source": "/getEvidenceUrl",
        "function": "getEvidenceUrl"
      },
      {
        "source": "/submitDisputeDecision",
        "function": "submitDisputeDecision"
      },
      {
        "source": "/submitRefundConfirmation",
        "function": "submitRefundConfirmation"
      },
      {
        "source": "/requestShareLink",
        "function": "requestShareLink"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
