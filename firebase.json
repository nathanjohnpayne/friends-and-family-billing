{
  "hosting": {
    "public": ".",
    "predeploy": [
      "node stamp-version.js"
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "DEPLOYMENT.md",
      "AGENTS.md",
      "QUICKSTART.md",
      "FIREBASE_IMPLEMENTATION.md",
      "README.md",
      "package.json",
      "tests/**",
      "functions/**",
      "stamp-version.js"
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "version.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "share.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/share",
        "destination": "/share.html"
      },
      {
        "source": "/resolveShareToken",
        "function": "resolveShareToken"
      },
      {
        "source": "/submitDispute",
        "function": "submitDispute"
      },
      {
        "source": "/getEvidenceUrl",
        "function": "getEvidenceUrl"
      },
      {
        "source": "/submitDisputeDecision",
        "function": "submitDisputeDecision"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
